{
  "name": "kioskoscope-booth-client",
  "version": "0.1.0",
  "private": true,
  "description": "Kioskoscope booth-client — parcours kiosque. Tourne dans une fenêtre navigateur en dev, en Chromium --kiosk sur la machine dédiée.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "esbuild scripts/focus_smoke.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/focus_smoke.mjs && node node_modules/.cache/focus_smoke.mjs",
    "test:logic": "esbuild scripts/logic_smoke.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/logic_smoke.mjs && node node_modules/.cache/logic_smoke.mjs"
  },
  "dependencies": {
    "@kioskoscope/domain": "*",
    "@supabase/supabase-js": "^2.45.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
